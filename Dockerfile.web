FROM node:20-alpine AS base

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
RUN npm ci --workspace=apps/web --workspace=packages/shared 2>/dev/null || npm install --workspace=apps/web

# Copy source
COPY packages/shared/ ./packages/shared/
COPY apps/web/ ./apps/web/

# Generate Prisma client
RUN cd apps/web && npx prisma generate

# Build
FROM base AS builder
WORKDIR /app/apps/web
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
# These are needed at build time for Next.js but values don't matter
ENV DATABASE_URL="postgresql://fake:fake@localhost:5432/fake"
ENV NEXTAUTH_SECRET="build-time-placeholder"
ENV NEXTAUTH_URL="http://localhost:3000"
ENV ANALYSIS_SERVICE_URL="http://localhost:8000"
RUN npx next build

# Production image
FROM node:20-alpine AS production
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Copy standalone output (preserves monorepo structure: apps/web/server.js)
COPY --from=builder /app/apps/web/.next/standalone ./
# Copy static assets into the correct location
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static

EXPOSE 3000
CMD ["node", "apps/web/server.js"]
