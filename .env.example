# ============================================
# ChessLens Environment Variables
# Copy this file to .env and fill in values
# ============================================

# ---------- Database ----------
DATABASE_URL="postgresql://chesslens:chesslens@localhost:5432/chesslens"

# ---------- Redis ----------
REDIS_URL="redis://localhost:6379/0"

# ---------- NextAuth ----------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# ---------- Lichess OAuth ----------
LICHESS_CLIENT_ID=""
LICHESS_CLIENT_SECRET=""

# ---------- Chess.com ----------
# Chess.com uses public API (no OAuth needed for game export)
# Optional: Chess.com OAuth for future features
CHESSCOM_CLIENT_ID=""
CHESSCOM_CLIENT_SECRET=""

# ---------- Azure OpenAI ----------
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_DEPLOYMENT="gpt-4o-mini"
AZURE_OPENAI_API_VERSION="2024-12-01-preview"

# ---------- Analysis Service ----------
ANALYSIS_SERVICE_URL="http://localhost:8000"
STOCKFISH_PATH="/usr/games/stockfish"
STOCKFISH_DEPTH=22
STOCKFISH_THREADS=2
STOCKFISH_HASH_MB=256

# ---------- CORS ----------
CORS_ORIGINS="http://localhost:3000"

# ---------- Syzygy Tablebase (optional) ----------
SYZYGY_PATH=""

# ---------- Celery ----------
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"
