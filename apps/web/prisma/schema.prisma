// This is your Prisma schema file for ChessLens
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth (NextAuth) ----------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Users ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  lichessId     String?   @unique
  chesscomUser  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  games       Game[]
  repertoires Repertoire[]
  reports     WeeklyReport[]
}

// ---------- Games ----------

model Game {
  id          String   @id @default(cuid())
  userId      String
  pgn         String   @db.Text
  source      String   // "lichess" | "chesscom" | "upload"
  sourceId    String?  // external game ID for deduplication
  white       String
  black       String
  result      String   // "1-0" | "0-1" | "1/2-1/2" | "*"
  eco         String?  // ECO opening code
  openingName String?
  timeControl String?
  timeClass   String?  // "bullet" | "blitz" | "rapid" | "classical" | "correspondence"
  whiteElo    Int?
  blackElo    Int?
  playedAt    DateTime?
  importedAt  DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis GameAnalysis?

  @@unique([userId, sourceId, source])
  @@index([userId, playedAt])
  @@index([userId, source])
}

// ---------- Game Analysis ----------

model GameAnalysis {
  id             String   @id @default(cuid())
  gameId         String   @unique
  engineDepth    Int      @default(22)
  moveEvals      Json     // Array of MoveEval objects
  accuracyWhite  Float?
  accuracyBlack  Float?
  totalMoves     Int?
  whiteBrilliant Int      @default(0)
  whiteGreat     Int      @default(0)
  whiteGood      Int      @default(0)
  whiteBook      Int      @default(0)
  whiteInaccuracy Int     @default(0)
  whiteMistake   Int      @default(0)
  whiteBlunder   Int      @default(0)
  blackBrilliant Int      @default(0)
  blackGreat     Int      @default(0)
  blackGood      Int      @default(0)
  blackBook      Int      @default(0)
  blackInaccuracy Int     @default(0)
  blackMistake   Int      @default(0)
  blackBlunder   Int      @default(0)
  aiReview       String?  @db.Text // AI coaching review (JSON string)
  status         String   @default("pending") // "pending" | "analyzing" | "complete" | "failed"
  analyzedAt     DateTime?

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

// ---------- Opening Repertoire ----------

model Repertoire {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   // "white" | "black"
  moves     Json     // RepertoireMove tree
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions RepertoirePosition[]

  @@index([userId])
}

model RepertoirePosition {
  id           String  @id @default(cuid())
  repertoireId String
  fen          String
  move         String
  annotation   String? @db.Text
  engineEval   Float?

  repertoire Repertoire @relation(fields: [repertoireId], references: [id], onDelete: Cascade)

  @@index([repertoireId, fen])
}

// ---------- Weekly Reports ----------

model WeeklyReport {
  id               String   @id @default(cuid())
  userId           String
  weekStart        DateTime
  gamesPlayed      Int      @default(0)
  wins             Int      @default(0)
  losses           Int      @default(0)
  draws            Int      @default(0)
  avgAccuracy      Float?
  ratingChange     Int?
  commonOpenings   Json?    // Array of { name, count, winRate }
  commonMistakes   Json?    // Array of { concept, count }
  improvementAreas Json?    // Array of strings
  aiSummary        String?  @db.Text
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
}
